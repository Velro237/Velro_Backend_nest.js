generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PendingUser {
  id                 String           @id @default(uuid())
  firstName          String?
  lastName           String?
  email              String
  phone              String?
  city               String?
  companyName        String?
  companyAddress     String?
  additionalInfo     String
  isFreightForwarder Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  otp_id             String
  expiresAt          DateTime
  username           String?
  lang               String?          @default("en")
  businessType       String?
  country            String?
  cities             CompanyCity[]    @relation("PendingUserCities")
  services           CompanyService[] @relation("PendingUserServices")
}

model CompanyCity {
  id           String        @id @default(uuid())
  name         String
  address      String
  contactName  String
  contactPhone String
  userId       String?
  pendingUsers PendingUser[] @relation("PendingUserCities")
  users        User[]        @relation("UserCities")
}

model CompanyService {
  id           String        @id @default(uuid())
  name         String
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  pendingUsers PendingUser[] @relation("PendingUserServices")
  users        User[]        @relation("UserServices")
}

model WithdrawalNumber {
  id        String   @id @default(uuid())
  number    String
  carrier   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user_id   String
  name      String
  user      User     @relation(fields: [user_id], references: [id])
}

model User {
  id                         String                 @id @default(uuid())
  email                      String
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  role                       UserRole               @default(USER)
  password                   String
  name                       String?
  picture                    String?
  device_id                  String?
  address                    String?
  city                       String?
  companyAddress             String?
  companyName                String?
  firstName                  String?
  isFreightForwarder         Boolean                @default(false)
  lastName                   String?
  phone                      String?
  state                      String?
  zip                        String?
  payout_country             String?
  payout_currency            String?                @default("EUR")
  stripe_account_id          String?                @unique
  stripe_onboarding_complete Boolean                @default(false)
  transfers_capability       String?                @default("inactive")
  currency                   String?                @default("XAF")
  username                   String?
  date_of_birth              DateTime?
  lang                       String?                @default("en")
  otpCode                    String?
  businessType               String?
  last_seen                  DateTime?
  is_suspended               Boolean                @default(false)
  status_message_en          String?
  status_message_fr          String?
  email_notification         Boolean                @default(true)
  push_notification          Boolean                @default(true)
  sms_notification           Boolean                @default(true)
  is_deleted                 Boolean                @default(false)
  flag_count                 Int                    @default(0)
  country                    String?
  accounts                   Account[]
  accountDeleteRequests      AccountDeleteRequest[]
  alerts                     Alert[]
  chats                      ChatMember[]
  delevries                  Delivery[]
  messages                   Message[]
  notifications              Notification[]
  offers                     Offer[]
  purchaseProofs             PurchaseProof[]
  ratingsGiven               Rating[]               @relation("RatingGiver")
  ratingsReceived            Rating[]               @relation("RatingReceiver")
  refreshTokens              RefreshToken[]
  reportsReplied             Report[]               @relation("ReportReplier")
  reportsReceived            Report[]               @relation("ReportReported")
  reportsSubmitted           Report[]               @relation("ReportReporter")
  shippingOffers             ShippingOffer[]        @relation("ShippingOffers")
  shippingRequests           ShippingRequest[]
  shoppingRequests           ShoppingRequest[]
  transactions               Transaction[]
  travelerStrikes            TravelerStrike[]
  trips                      Trip[]
  requests                   TripRequest[]
  kycRecords                 UserKYC[]
  wallet                     Wallet?
  withdrawalNumbers          WithdrawalNumber[]
  cities                     CompanyCity[]          @relation("UserCities")
  services                   CompanyService[]       @relation("UserServices")
}

model Delivery {
  id               String            @id @default(cuid())
  userId           String
  total_cost       Decimal           @db.Decimal(10, 2)
  description      String?
  currency         Currency
  status           DeliveryStatus    @default(PENDING)
  reward           Int               @default(15)
  expected_date    DateTime
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  is_deleted       Boolean           @default(false)
  data             Json?
  transaction_id   String?           @unique
  transaction      Transaction?      @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryProducts DeliveryProduct[]

  @@index([userId])
  @@index([transaction_id])
}

model DeliveryProduct {
  id          String   @id @default(cuid())
  deliveryId  String
  price       Decimal  @db.Decimal(10, 2)
  currency    Currency
  name        String
  url         String?
  weight      Decimal? @db.Decimal(10, 2)
  description String?
  quantity    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  delivery    Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

model Account {
  id                String    @id @default(cuid())
  userId            String
  provider          Provider
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  idToken           String?
  expiresAt         DateTime?
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Chat {
  id                  String           @id @default(uuid())
  name                String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  trip_id             String?
  type                ChatType         @default(TRIP)
  is_flagged          Boolean          @default(false)
  shipping_request_id String?
  shopping_request_id String?
  shippingRequest     ShippingRequest? @relation(fields: [shipping_request_id], references: [id], onDelete: Cascade)
  shoppingRequest     ShoppingRequest? @relation(fields: [shopping_request_id], references: [id], onDelete: Cascade)
  trip                Trip?            @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  members             ChatMember[]
  messages            Message[]
  offer               Offer?           @relation("OfferChat")
  shippingOffer       ShippingOffer?   @relation("ShippingOfferChat")
  request             TripRequest?
}

model ChatMember {
  id        String   @id @default(uuid())
  chat_id   String
  user_id   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  joinedAt  DateTime @default(now())
  chat      Chat     @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, chat_id])
}

model Message {
  id          String       @id @default(uuid())
  chat_id     String
  sender_id   String
  content     String?
  image_url   String?
  request_id  String?
  type        MessageType  @default(TEXT)
  isRead      Boolean      @default(false)
  createdAt   DateTime     @default(now())
  reply_to_id String?
  review_id   String?
  data        Json?
  is_flagged  Boolean      @default(false)
  chat        Chat         @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  reply_to    Message?     @relation("MessageReplies", fields: [reply_to_id], references: [id])
  replies     Message[]    @relation("MessageReplies")
  request     TripRequest? @relation(fields: [request_id], references: [id], onDelete: Cascade)
  sender      User         @relation(fields: [sender_id], references: [id], onDelete: Cascade)
}

model Trip {
  id                   String          @id @default(uuid())
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  destination          Json?
  maximum_weight_in_kg Decimal?        @db.Decimal(5, 2)
  mode_of_transport_id String?
  notes                String?
  pickup               Json?
  status               TripStatus      @default(SCHEDULED)
  user_id              String
  arrival_date         DateTime?
  arrival_time         String?
  departure            Json?
  departure_date       DateTime
  departure_time       String
  meetup_flexible      Boolean         @default(false)
  delivery             Json?
  airline_id           String
  fully_booked         Boolean         @default(false)
  currency             Currency        @default(USD)
  is_deleted           Boolean         @default(false)
  chats                Chat[]
  ratings              Rating[]
  reports              Report[]
  transactions         Transaction[]
  airline              Airline         @relation(fields: [airline_id], references: [id], onDelete: Cascade)
  mode_of_transport    TransportType?  @relation(fields: [mode_of_transport_id], references: [id], onDelete: Cascade)
  user                 User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  trip_items           TripItemsList[]
  requests             TripRequest[]
}

model Airline {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  trips       Trip[]
}

model Image {
  id                      String             @id @default(uuid())
  object_id               String
  url                     String
  alt_text                String?
  created_at              DateTime           @default(now())
  updated_at              DateTime           @updatedAt
  proofImages             ProofImage[]
  purchaseProofsAsPrimary PurchaseProof[]
  trip_items              TripItem[]
  requestLinks            TripRequestImage[]
}

model PurchaseProof {
  id                       String              @id @default(uuid())
  offer_id                 String?
  uploader_id              String
  status                   ProofStatus         @default(PENDING)
  primary_receipt_image_id String?
  metadata                 Json?
  created_at               DateTime            @default(now())
  updated_at               DateTime            @updatedAt
  proof_images             ProofImage[]
  verifications            ProofVerification[]
  offer                    Offer?              @relation(fields: [offer_id], references: [id], onDelete: Cascade)
  primary_receipt_image    Image?              @relation(fields: [primary_receipt_image_id], references: [id])
  uploader                 User                @relation(fields: [uploader_id], references: [id], onDelete: Cascade)

  @@index([offer_id])
  @@index([uploader_id])
}

model ProofImage {
  id       String         @id @default(uuid())
  proof_id String
  image_id String
  type     ProofImageType
  ord      Int?
  image    Image          @relation(fields: [image_id], references: [id], onDelete: Cascade)
  proof    PurchaseProof  @relation(fields: [proof_id], references: [id], onDelete: Cascade)

  @@index([proof_id])
  @@index([image_id])
}

model ProofVerification {
  id          String        @id @default(uuid())
  proof_id    String
  verified_by String?
  decision    ProofDecision
  reason      String?
  created_at  DateTime      @default(now())
  proof       PurchaseProof @relation(fields: [proof_id], references: [id], onDelete: Cascade)

  @@index([proof_id])
}

model TripItem {
  id              String            @id @default(uuid())
  name            String            @unique
  description     String?
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  image_id        String?
  translations    Translation[]
  image           Image?            @relation(fields: [image_id], references: [id])
  trip_items_list TripItemsList[]
  request_items   TripRequestItem[]
}

model Translation {
  id           String    @id @default(uuid())
  name         String
  description  String?
  language     Language  @default(en)
  trip_item_id String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  tripItem     TripItem? @relation(fields: [trip_item_id], references: [id], onDelete: Cascade)

  @@unique([trip_item_id, language])
}

model TripItemsList {
  trip_id       String
  trip_item_id  String
  price         Decimal              @db.Decimal(10, 2)
  created_at    DateTime             @default(now())
  updated_at    DateTime             @updatedAt
  avalailble_kg Decimal?             @db.Decimal(10, 2)
  trip          Trip                 @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  trip_item     TripItem             @relation(fields: [trip_item_id], references: [id], onDelete: Cascade)
  prices        TripItemsListPrice[]

  @@id([trip_id, trip_item_id])
}

model TripItemsListPrice {
  trip_id         String
  trip_item_id    String
  currency        Currency
  price           Decimal       @db.Decimal(10, 2)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt
  trip_items_list TripItemsList @relation(fields: [trip_id, trip_item_id], references: [trip_id, trip_item_id], onDelete: Cascade)

  @@id([trip_id, trip_item_id, currency])
}

model TripRequest {
  id                          String             @id @default(uuid())
  trip_id                     String
  user_id                     String
  status                      RequestStatus      @default(PENDING)
  message                     String?
  created_at                  DateTime           @default(now())
  updated_at                  DateTime           @updatedAt
  cost                        Decimal?           @db.Decimal(10, 2)
  delivered_at                DateTime?
  paid_at                     DateTime?
  payment_intent_id           String?            @unique
  payment_status              PaymentStatus?     @default(PENDING)
  sender_confirmed_delivery   Boolean            @default(false)
  traveler_confirmed_delivery Boolean            @default(false)
  chat_id                     String?            @unique
  cancellation_reason         String?
  cancellation_type           String?
  cancelled_at                DateTime?
  currency                    Currency?
  is_deleted                  Boolean            @default(false)
  messages                    Message[]
  ratings                     Rating[]
  reports                     Report[]
  transactions                Transaction[]
  chat                        Chat?              @relation(fields: [chat_id], references: [id])
  trip                        Trip               @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  user                        User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  images                      TripRequestImage[]
  request_items               TripRequestItem[]
}

model TripRequestItem {
  request_id    String
  trip_item_id  String
  quantity      Int
  special_notes String?
  request       TripRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)
  trip_item     TripItem    @relation(fields: [trip_item_id], references: [id], onDelete: Cascade)

  @@id([request_id, trip_item_id])
}

model TripRequestImage {
  trip_request_id String
  image_id        String
  created_at      DateTime    @default(now())
  image           Image       @relation(fields: [image_id], references: [id], onDelete: Cascade)
  tripRequest     TripRequest @relation(fields: [trip_request_id], references: [id], onDelete: Cascade)

  @@id([trip_request_id, image_id])
}

model TransportType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  trips       Trip[]
}

model Report {
  id          String         @id @default(uuid())
  user_id     String
  reported_id String
  reply_to_id String?
  trip_id     String
  request_id  String?
  type        ReportType
  text        String?
  priority    ReportPriority
  status      ReportStatus   @default(PENDING)
  data        Json?
  replied_by  String?
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  images      Json?
  replier     User?          @relation("ReportReplier", fields: [replied_by], references: [id])
  replyTo     Report?        @relation("ReportReplies", fields: [reply_to_id], references: [id])
  replies     Report[]       @relation("ReportReplies")
  reported    User           @relation("ReportReported", fields: [reported_id], references: [id], onDelete: Cascade)
  request     TripRequest?   @relation(fields: [request_id], references: [id], onDelete: Cascade)
  trip        Trip           @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  user        User           @relation("ReportReporter", fields: [user_id], references: [id], onDelete: Cascade)
}

model UserKYC {
  id               String      @id @default(uuid())
  userId           String
  diditSessionId   String?     @unique
  diditWorkflowId  String?
  sessionUrl       String?
  callbackUrl      String?
  status           KYCStatus   @default(NOT_STARTED)
  provider         KYCProvider @default(DIDIT)
  verificationData Json?
  rejectionReason  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  verifiedAt       DateTime?
  expiresAt        DateTime?
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Rating {
  id                  String           @id @default(uuid())
  giver_id            String
  receiver_id         String
  trip_id             String?
  request_id          String?
  rating              Int
  comment             String?
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt
  shopping_request_id String?
  giver               User             @relation("RatingGiver", fields: [giver_id], references: [id], onDelete: Cascade)
  receiver            User             @relation("RatingReceiver", fields: [receiver_id], references: [id], onDelete: Cascade)
  request             TripRequest?     @relation(fields: [request_id], references: [id], onDelete: Cascade)
  shoppingRequest     ShoppingRequest? @relation(fields: [shopping_request_id], references: [id], onDelete: Cascade)
  trip                Trip?            @relation(fields: [trip_id], references: [id], onDelete: Cascade)

  @@unique([giver_id, receiver_id, trip_id])
}

model Alert {
  id            String    @id @default(uuid())
  user_id       String
  depature      String
  destination   String
  form_date     DateTime?
  to_date       DateTime?
  notificaction Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Notification {
  id         String           @id @default(uuid())
  user_id    String
  title      String
  message    String
  type       NotificationType
  data       Json?
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())
  read_at    DateTime?
  request_id String?
  trip_id    String?
  user       User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Wallet {
  id                    String        @id @default(uuid())
  userId                String        @unique
  available_balance     Decimal       @default(0.00) @db.Decimal(10, 2)
  hold_balance          Decimal       @default(0.00) @db.Decimal(10, 2)
  total_balance         Decimal       @default(0.00) @db.Decimal(10, 2)
  state                 WalletState   @default(BLOCKED)
  currency              String        @default("XAF")
  updatedAt             DateTime      @updatedAt
  createdAt             DateTime      @default(now())
  available_balance_cad Decimal       @default(0) @db.Decimal(10, 2)
  available_balance_eur Decimal       @default(0) @db.Decimal(10, 2)
  available_balance_usd Decimal       @default(0) @db.Decimal(10, 2)
  available_balance_xaf Decimal       @default(0) @db.Decimal(10, 2)
  hold_balance_cad      Decimal       @default(0) @db.Decimal(10, 2)
  hold_balance_eur      Decimal       @default(0) @db.Decimal(10, 2)
  hold_balance_usd      Decimal       @default(0) @db.Decimal(10, 2)
  hold_balance_xaf      Decimal       @default(0) @db.Decimal(10, 2)
  status_message_en     String?
  status_message_fr     String?
  transactions          Transaction[]
  user                  User          @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Transaction {
  id                 String              @id @default(uuid())
  userId             String
  trip_id            String?
  request_id         String?
  type               TransactionType
  status             TransactionStatus   @default(PENDING)
  reference          String?             @unique
  provider           TransactionProvider
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  amount_paid        Decimal             @db.Decimal(10, 2)
  amount_requested   Decimal             @db.Decimal(10, 2)
  currency           String
  description        String?
  fee_applied        Decimal             @db.Decimal(10, 2)
  metadata           Json?
  processedAt        DateTime?
  source             TransactionSource
  status_message     String?
  wallet_id          String
  balance_after      Decimal?            @db.Decimal(10, 2)
  stripe_account_id  String?
  stripe_transfer_id String?             @unique
  phone_number       String?
  provider_id        String?
  delivery           Delivery?
  request            TripRequest?        @relation(fields: [request_id], references: [id], onDelete: Cascade)
  trip               Trip?               @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet             Wallet              @relation(fields: [wallet_id], references: [id])

  @@index([userId, createdAt])
  @@index([reference])
  @@index([stripe_transfer_id])
}

model Otp {
  id         String   @id @default(uuid())
  code       String
  email      String?
  phone      String?
  type       OtpType
  expiresAt  DateTime
  verified   Boolean  @default(false)
  access_key String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AccountDeleteRequest {
  id        String              @id @default(uuid())
  email     String
  reason    String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  status    deleteRequestStatus @default(PENDING)
  user_id   String
  user      User                @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([email])
}

model Logger {
  id            String     @id @default(uuid())
  user_id       String
  error_message String
  type          loggerType
  data          Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model ShippingRequest {
  id                  String                    @id @default(uuid())
  user_id             String
  category            ShippingCategory
  package_photo_urls  String[]
  package_description String
  details_description String?
  from                String
  to                  String
  delivery_timeframe  ShippingDeliveryTimeframe
  weight              ShippingWeight
  packaging           Boolean                   @default(false)
  traveler_reward     Decimal
  reward_currency     Currency?                 @default(XAF)
  status              ShippingRequestStatus     @default(PUBLISHED)
  created_at          DateTime                  @default(now())
  updated_at          DateTime                  @updatedAt
  chats               Chat[]
  offers              ShippingOffer[]
  user                User                      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([delivery_timeframe])
  @@index([weight])
  @@index([status])
  @@index([category])
  @@index([from])
  @@index([to])
  @@index([created_at])
  @@index([traveler_reward])
}

model ShippingOffer {
  id                  String          @id @default(uuid())
  shipping_request_id String
  traveler_id         String
  reward_amount       Decimal
  reward_currency     Currency?       @default(XAF)
  travel_date         DateTime?
  message             String?
  chat_id             String?         @unique
  status              OfferStatus     @default(PENDING)
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  accepted_at         DateTime?
  rejected_at         DateTime?
  cancelled_at        DateTime?
  delivered_at        DateTime?
  chat                Chat?           @relation("ShippingOfferChat", fields: [chat_id], references: [id])
  shipping_request    ShippingRequest @relation(fields: [shipping_request_id], references: [id], onDelete: Cascade)
  traveler            User            @relation("ShippingOffers", fields: [traveler_id], references: [id], onDelete: Cascade)

  @@index([shipping_request_id])
  @@index([traveler_id])
  @@index([status])
  @@index([chat_id])
}

model Product {
  id                  String          @id @default(uuid())
  shopping_request_id String
  name                String
  description         String?
  source              ProductSource
  url                 String?
  image_urls          String[]
  price               Decimal
  price_currency      Currency
  weight              Decimal?
  quantity            Int             @default(1)
  variants            Json?
  in_stock            Boolean         @default(true)
  availability_text   String?
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  shopping_request    ShoppingRequest @relation(fields: [shopping_request_id], references: [id], onDelete: Cascade)

  @@index([shopping_request_id])
}

model ShoppingRequest {
  id                          String                @id @default(uuid())
  user_id                     String
  version                     Int                   @default(1)
  current_version             Int                   @default(1)
  last_edited_at              DateTime?
  source                      RequestSource
  deliver_to                  String
  delivery_timeframe          DeliveryTimeframe
  packaging_option            Boolean               @default(false)
  product_price               Decimal
  product_currency            Currency
  traveler_reward             Decimal
  platform_fee                Decimal
  additional_fees             Decimal               @default(0)
  total_cost                  Decimal
  suggested_reward_percentage Decimal               @default(15)
  reward_currency             Currency
  status                      ShoppingRequestStatus @default(PUBLISHED)
  expires_at                  DateTime?
  additional_notes            String?
  purchase_proof_url          String?
  purchase_proof_uploaded_at  DateTime?
  created_at                  DateTime              @default(now())
  updated_at                  DateTime              @updatedAt
  paid_at                     DateTime?
  bought_at                   DateTime?
  delivered_at                DateTime?
  completed_at                DateTime?
  cancelled_at                DateTime?
  cancelled_by_id             String?
  chats                       Chat[]
  deliveryTracking            DeliveryTracking?
  offers                      Offer[]
  products                    Product[]
  ratings                     Rating[]
  user                        User                  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
  @@index([expires_at])
  @@index([created_at])
}

model Offer {
  id                  String          @id @default(uuid())
  shopping_request_id String
  traveler_id         String
  request_version     Int
  reward_amount       Decimal
  reward_currency     Currency
  additional_fees     Decimal         @default(0)
  travel_date         DateTime?
  message             String?
  status              OfferStatus     @default(PENDING)
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  accepted_at         DateTime?
  rejected_at         DateTime?
  cancelled_at        DateTime?
  chat_id             String?         @unique
  chat                Chat?           @relation("OfferChat", fields: [chat_id], references: [id])
  shopping_request    ShoppingRequest @relation(fields: [shopping_request_id], references: [id], onDelete: Cascade)
  traveler            User            @relation(fields: [traveler_id], references: [id], onDelete: Cascade)
  purchase_proofs     PurchaseProof[]

  @@index([shopping_request_id])
  @@index([traveler_id])
  @@index([status])
  @@index([request_version])
  @@index([chat_id])
}

model DeliveryTracking {
  id                  String          @id @default(uuid())
  shopping_request_id String          @unique
  marked_delivered_at DateTime?
  auto_release_at     DateTime?
  confirmed_at        DateTime?
  confirmed_by        String?
  issue_reported      Boolean         @default(false)
  issue_reported_at   DateTime?
  issue_reported_by   String?
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  shopping_request    ShoppingRequest @relation(fields: [shopping_request_id], references: [id], onDelete: Cascade)

  @@index([auto_release_at])
  @@index([marked_delivered_at])
}

model TravelerStrike {
  id                  String    @id @default(uuid())
  traveler_id         String
  offer_id            String
  shopping_request_id String
  cancelled_at        DateTime  @default(now())
  is_banned           Boolean   @default(false)
  banned_at           DateTime?
  created_at          DateTime  @default(now())
  traveler            User      @relation(fields: [traveler_id], references: [id], onDelete: Cascade)

  @@index([traveler_id])
  @@index([is_banned])
}

