// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(uuid())
  email     String        @unique
  role      UserRole      @default(USER)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  trips     Trip[]
  requests  TripRequest[]
}

model Trip {
  id                   String     @id @default(uuid())
  user_id              String
  pickup               Json?
  destination          Json?
  departure            Json?
  delivery             Json?
  departure_date       DateTime
  departure_time       String
  arrival_date         DateTime?
  arrival_time         String?
  mode_of_transport_id String
  maximum_weight_in_kg Decimal?   @db.Decimal(5, 2)
  notes                String?
  fullSuitcaseOnly     Boolean    @default(false)
  meetup_flexible      Boolean    @default(false)
  price_per_kg         Decimal    @db.Decimal(10, 2)
  status               TripStatus @default(PUBLISHED)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  // Relations
  user              User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  mode_of_transport TransportType   @relation(fields: [mode_of_transport_id], references: [id], onDelete: Cascade)
  trip_items        TripItemsList[]
  requests          TripRequest[]
}

// Image Model - For storing image references
model Image {
  id         String   @id @default(uuid())
  object_id  String   @unique // ObjectId pointing to the schema having the image
  url        String
  alt_text   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  trip_items TripItem[]
  requests   TripRequest[]
}

// Trip Item Model - Predefined items that can be added to travel listings
model TripItem {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  image_id    String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  trip_items_list TripItemsList[]
  request_items   TripRequestItem[]
  image           Image?            @relation(fields: [image_id], references: [id], onDelete: SetNull)
}

// Junction table for TravelListing and TripItem with custom pricing
model TripItemsList {
  trip_id      String
  trip_item_id String
  price        Decimal  @db.Decimal(10, 2)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Relations
  trip      Trip     @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  trip_item TripItem @relation(fields: [trip_item_id], references: [id], onDelete: Cascade)

  @@id([trip_id, trip_item_id])
}

// Trip Request Model - For users to request items from trips
model TripRequest {
  id         String        @id @default(uuid())
  trip_id    String
  user_id    String
  status     RequestStatus @default(PENDING)
  message    String?
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  // Relations
  trip          Trip              @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  request_items TripRequestItem[]
  images        Image[]
}

// Trip Request Item Model - For storing quantities of requested items
model TripRequestItem {
  request_id    String
  trip_item_id  String
  quantity      Int
  special_notes String?

  // Relations
  request   TripRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)
  trip_item TripItem    @relation(fields: [trip_item_id], references: [id], onDelete: Cascade)

  @@id([request_id, trip_item_id])
}

model TransportType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  trips Trip[]
}

enum UserRole {
  USER
  ADMIN
}

enum userStatus {
  ACTIVE
  INACTIVE
}

enum TripStatus {
  PUBLISHED
  CANCELLED
  COMPLETED
  FULLY_BOOKED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}
