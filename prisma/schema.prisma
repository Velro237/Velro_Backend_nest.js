enum MessageType {
  TEXT
  IMAGE
  REQUEST
  PAYMENT
}

model Trip {
  id                   String     @id @default(uuid())
  user_id              String
  pickup               Json?
  destination          Json?
  departure            Json?
  delivery             Json?
  departure_date       DateTime
  departure_time       String
  arrival_date         DateTime?
  arrival_time         String?
  mode_of_transport_id String
  maximum_weight_in_kg Decimal?   @db.Decimal(5, 2)
  notes                String?
  fullSuitcaseOnly     Boolean    @default(false)
  meetup_flexible      Boolean    @default(false)
  price_per_kg         Decimal    @db.Decimal(10, 2)
  status               TripStatus @default(PUBLISHED)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  // Relations
  user              User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  mode_of_transport TransportType   @relation(fields: [mode_of_transport_id], references: [id], onDelete: Cascade)
  trip_items        TripItemsList[]
  requests          TripRequest[]
  chats             Chat[]
  reports           Report[]
}

model Image {
  id         String   @id @default(uuid())
  object_id  String // optional pointer to external object if needed
  url        String
  alt_text   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  trip_items   TripItem[]
  requestLinks TripRequestImage[]
}

model TripItem {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  image_id    String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  trip_items_list TripItemsList[]
  request_items   TripRequestItem[]
  image           Image?            @relation(fields: [image_id], references: [id], onDelete: SetNull)
}

model TripItemsList {
  trip_id      String
  trip_item_id String
  price        Decimal  @db.Decimal(10, 2)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Relations
  trip      Trip     @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  trip_item TripItem @relation(fields: [trip_item_id], references: [id], onDelete: Cascade)

  @@id([trip_id, trip_item_id])
}

model TripRequest {
  id         String        @id @default(uuid())
  trip_id    String
  user_id    String
  status     RequestStatus @default(PENDING)
  message    String?
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  // Relations
  trip          Trip               @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  request_items TripRequestItem[]
  images        TripRequestImage[]
  messages      Message[] // messages that reference this request via request_id
  reports       Report[]
}

model TripRequestItem {
  request_id    String
  trip_item_id  String
  quantity      Int
  special_notes String?

  // Relations
  request   TripRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)
  trip_item TripItem    @relation(fields: [trip_item_id], references: [id], onDelete: Cascade)

  @@id([request_id, trip_item_id])
}

// join table to attach images to trip requests (explicit FK)
model TripRequestImage {
  trip_request_id String
  image_id        String
  created_at      DateTime @default(now())

  tripRequest TripRequest @relation(fields: [trip_request_id], references: [id], onDelete: Cascade)
  image       Image       @relation(fields: [image_id], references: [id], onDelete: Cascade)

  @@id([trip_request_id, image_id])
}

model TransportType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  trips Trip[]
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TripStatus {
  PUBLISHED
  CANCELLED
  COMPLETED
  FULLY_BOOKED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ReportType {
  TRAVEL_ISSUES
  OTHER_ISSUES
  RESPONSE_TO_REPORT
}

enum ReportPriority {
  HIGH
  LOW
}

enum ReportStatus {
  PENDING
  REPLIED
}

model Report {
  id          String         @id @default(uuid())
  user_id     String // User reporting
  reported_id String // User being reported
  reply_to_id String? // ID of report we are replying to (not required)
  trip_id     String // Trip ID (required)
  request_id  String? // Request ID (not required)
  type        ReportType
  text        String? // Report text (not required)
  priority    ReportPriority
  status      ReportStatus   @default(PENDING)
  data        Json? // Additional data in JSON format
  replied_by  String? // ID of user replying to report (not required)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  images      Json?

  // Relations
  user     User         @relation("ReportReporter", fields: [user_id], references: [id], onDelete: Cascade)
  reported User         @relation("ReportReported", fields: [reported_id], references: [id], onDelete: Cascade)
  replyTo  Report?      @relation("ReportReplies", fields: [reply_to_id], references: [id])
  replies  Report[]     @relation("ReportReplies")
  trip     Trip         @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  request  TripRequest? @relation(fields: [request_id], references: [id], onDelete: Cascade)
  replier  User?        @relation("ReportReplier", fields: [replied_by], references: [id])
}
