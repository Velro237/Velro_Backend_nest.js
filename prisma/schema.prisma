generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Provider {
  GOOGLE
  APPLE
}

model PendingUser {
  id                 String  @id @default(uuid())
  firstName          String?
  lastName           String?
  email              String
  username           String?
  phone              String?
  city               String?
  companyName        String?
  companyAddress     String?
  businessType       String?
  additionalInfo     String
  isFreightForwarder Boolean @default(false)
  otp_id             String
  lang               String? @default("en")

  // Relation
  services CompanyService[] @relation("PendingUserServices")
  cities   CompanyCity[]    @relation("PendingUserCities")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime
}

model CompanyCity {
  id           String @id @default(uuid())
  name         String
  address      String
  contactName  String
  contactPhone String

  pendingUsers PendingUser[] @relation("PendingUserCities")
  users        User[]        @relation("UserCities")
  userId       String?
}

model CompanyService {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]   @relation("UserServices")

  // Relation
  pendingUsers PendingUser[] @relation("PendingUserServices")
}

model WithdrawalNumber {
  id        String   @id @default(uuid())
  number    String
  carrier   String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user    User   @relation(fields: [user_id], references: [id])
  user_id String
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String?
  password      String
  firstName     String?
  lastName      String?
  phone         String?
  address       String?
  city          String?
  state         String?
  zip           String?
  picture       String?
  currency      String?   @default("XAF")
  lang          String?   @default("en")
  date_of_birth DateTime?
  otpCode       String?
  businessType  String?

  name               String?
  isFreightForwarder Boolean            @default(false)
  companyName        String?
  companyAddress     String?
  device_id          String?
  role               UserRole           @default(USER)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  trips              Trip[]
  requests           TripRequest[]
  messages           Message[]
  chats              ChatMember[]
  withdrawalNumbers  WithdrawalNumber[]

  // Stripe Connect fields
  stripe_account_id          String? @unique
  payout_country             String?
  payout_currency            String? @default("EUR")
  transfers_capability       String? @default("inactive")
  stripe_onboarding_complete Boolean @default(false)

  services CompanyService[] @relation("UserServices")
  cities   CompanyCity[]    @relation("UserCities")

  reportsSubmitted      Report[]               @relation("ReportReporter")
  reportsReceived       Report[]               @relation("ReportReported")
  reportsReplied        Report[]               @relation("ReportReplier")
  refreshTokens         RefreshToken[]
  accounts              Account[]
  kycRecords            UserKYC[]
  alerts                Alert[]
  ratingsGiven          Rating[]               @relation("RatingGiver")
  ratingsReceived       Rating[]               @relation("RatingReceiver")
  notifications         Notification[]
  wallet                Wallet?
  transactions          Transaction[]
  accountDeleteRequests AccountDeleteRequest[]
}

model Account {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider          Provider
  providerAccountId String // "sub" (Google/Apple subject)
  accessToken       String?
  refreshToken      String?
  idToken           String?
  expiresAt         DateTime?

  @@unique([provider, providerAccountId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique // (en pratique: stocke un hash)
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Chat {
  id      String  @id @default(uuid())
  name    String?
  trip_id String? // Optional: link to trip (multiple chats allowed per trip)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ChatMember[]
  messages Message[]
  trip     Trip?        @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  request  TripRequest? // One-to-one reverse relation
}

model ChatMember {
  id        String   @id @default(uuid())
  chat_id   String
  user_id   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  joinedAt DateTime @default(now())

  // Relations
  chat Chat @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, chat_id]) // Prevent duplicate memberships
}

model Message {
  id String @id @default(uuid())

  chat_id   String
  sender_id String
  chat      Chat   @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  sender    User   @relation(fields: [sender_id], references: [id], onDelete: Cascade)
  data      Json?

  content    String? // Text message
  image_url  String? // Optional for media messages
  request_id String? // Optional for request messages
  review_id  String? // Optional for review messages

  type MessageType @default(TEXT)

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Optional: for threaded messages/replies
  reply_to_id String?
  reply_to    Message?  @relation("MessageReplies", fields: [reply_to_id], references: [id])
  replies     Message[] @relation("MessageReplies")

  // Relation to TripRequest (if the message references a trip request)
  request TripRequest? @relation(fields: [request_id], references: [id], onDelete: Cascade)
}

enum MessageType {
  TEXT
  IMAGE
  REQUEST
  PAYMENT
  SYSTEM
  REVIEW
}

model Trip {
  id                   String    @id @default(uuid())
  user_id              String
  pickup               Json?
  destination          Json?
  departure            Json?
  delivery             Json?
  departure_date       DateTime
  departure_time       String
  currency             Currency  @default(USD)
  arrival_date         DateTime?
  arrival_time         String?
  mode_of_transport_id String?
  airline_id           String
  maximum_weight_in_kg Decimal?  @db.Decimal(5, 2)
  notes                String?
  fully_booked         Boolean   @default(false)

  meetup_flexible Boolean    @default(false)
  status          TripStatus @default(SCHEDULED)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  user              User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  mode_of_transport TransportType?  @relation(fields: [mode_of_transport_id], references: [id], onDelete: Cascade)
  airline           Airline         @relation(fields: [airline_id], references: [id], onDelete: Cascade)
  trip_items        TripItemsList[]
  requests          TripRequest[]
  chats             Chat[]
  reports           Report[]
  ratings           Rating[]
  transactions      Transaction[]
}

enum Currency {
  XAF
  USD
  EUR
  CAD
}

model Airline {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  trips Trip[]
}

model Image {
  id         String   @id @default(uuid())
  object_id  String // optional pointer to external object if needed
  url        String
  alt_text   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  trip_items   TripItem[]
  requestLinks TripRequestImage[]
}

enum Language {
  en
  fr
}

model TripItem {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  image_id    String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  image           Image?            @relation(fields: [image_id], references: [id], onDelete: SetNull)
  trip_items_list TripItemsList[]
  request_items   TripRequestItem[]

  // ✅ Link to translations
  translations Translation[]
}

model Translation {
  id           String   @id @default(uuid())
  name         String
  description  String?
  language     Language @default(en)
  trip_item_id String? // foreign key to TripItem

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tripItem TripItem? @relation(fields: [trip_item_id], references: [id], onDelete: Cascade)

  @@unique([trip_item_id, language]) // prevent duplicate language per TripItem
}

model TripItemsList {
  trip_id       String
  trip_item_id  String
  price         Decimal  @db.Decimal(10, 2)
  avalailble_kg Decimal? @db.Decimal(10, 2)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  trip      Trip                 @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  trip_item TripItem             @relation(fields: [trip_item_id], references: [id], onDelete: Cascade)
  prices    TripItemsListPrice[]

  @@id([trip_id, trip_item_id])
}

model TripItemsListPrice {
  trip_id      String
  trip_item_id String
  currency     Currency
  price        Decimal  @db.Decimal(10, 2)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  // Relations
  trip_items_list TripItemsList @relation(fields: [trip_id, trip_item_id], references: [trip_id, trip_item_id], onDelete: Cascade)

  @@id([trip_id, trip_item_id, currency])
}

model TripRequest {
  id         String        @id @default(uuid())
  trip_id    String
  user_id    String
  status     RequestStatus @default(PENDING)
  message    String?
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt
  cost       Decimal?      @db.Decimal(10, 2)

  // Payment fields
  currency          Currency?
  payment_intent_id String?        @unique
  payment_status    PaymentStatus? @default(PENDING)
  paid_at           DateTime?

  // Delivery confirmation
  sender_confirmed_delivery   Boolean   @default(false)
  traveler_confirmed_delivery Boolean   @default(false)
  delivered_at                DateTime?

  // Cancellation fields
  cancelled_at        DateTime?
  cancellation_type   String?
  cancellation_reason String?

  // Chat relation (one-to-one)
  chat_id String? @unique

  // Relations
  trip          Trip               @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  chat          Chat?              @relation(fields: [chat_id], references: [id], onDelete: SetNull)
  request_items TripRequestItem[]
  images        TripRequestImage[]
  messages      Message[] // messages that reference this request via request_id
  reports       Report[]
  ratings       Rating[]
  transactions  Transaction[]
}

model TripRequestItem {
  request_id    String
  trip_item_id  String
  quantity      Int
  special_notes String?

  // Relations
  request   TripRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)
  trip_item TripItem    @relation(fields: [trip_item_id], references: [id], onDelete: Cascade)

  @@id([request_id, trip_item_id])
}

// join table to attach images to trip requests (explicit FK)
model TripRequestImage {
  trip_request_id String
  image_id        String
  created_at      DateTime @default(now())

  tripRequest TripRequest @relation(fields: [trip_request_id], references: [id], onDelete: Cascade)
  image       Image       @relation(fields: [image_id], references: [id], onDelete: Cascade)

  @@id([trip_request_id, image_id])
}

model TransportType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  trips Trip[]
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TripStatus {
  PUBLISHED
  SCHEDULED
  RESCHEDULED
  INPROGRESS
  CANCELLED
  COMPLETED
  DRAFT
}

enum RequestStatus {
  PENDING //when the request is created
  ACCEPTED //when the request is accepted by the traveler
  DECLINED //when the request is declined by the traveler
  CANCELLED //when the request is cancelled by the traveler or sender
  REFUNDED //when the request is refunded to the sender
  EXPIRED //when the traveller do not accept the request before the departure date
  CONFIRMED //when the request is paid by the sender
  SENT //when user confrin send package to traveller
  RECEIVED //when traveller confirm received package from user
  IN_TRANSIT //when travel date and time arrives
  PENDING_DELIVERY //traveller mark as delivered but not confirmed by user
  DELIVERED //when the user confirm package is delivered by the traveler
}

enum ReportType {
  TRAVEL_ISSUES
  OTHER_ISSUES
  RESPONSE_TO_REPORT
}

enum ReportPriority {
  HIGH
  LOW
}

enum ReportStatus {
  PENDING
  REPLIED
}

model Report {
  id          String         @id @default(uuid())
  user_id     String // User reporting
  reported_id String // User being reported
  reply_to_id String? // ID of report we are replying to (not required)
  trip_id     String // Trip ID (required)
  request_id  String? // Request ID (not required)
  type        ReportType
  text        String? // Report text (not required)
  priority    ReportPriority
  status      ReportStatus   @default(PENDING)
  data        Json? // Additional data in JSON format
  replied_by  String? // ID of user replying to report (not required)
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  images      Json?

  // Relations
  user     User         @relation("ReportReporter", fields: [user_id], references: [id], onDelete: Cascade)
  reported User         @relation("ReportReported", fields: [reported_id], references: [id], onDelete: Cascade)
  replyTo  Report?      @relation("ReportReplies", fields: [reply_to_id], references: [id])
  replies  Report[]     @relation("ReportReplies")
  trip     Trip         @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  request  TripRequest? @relation(fields: [request_id], references: [id], onDelete: Cascade)
  replier  User?        @relation("ReportReplier", fields: [replied_by], references: [id])
}

// KYC Verification Models
enum KYCStatus {
  NOT_STARTED // The verification process has not been initiated by the user yet
  IN_PROGRESS // The user has started the verification process and is currently submitting information
  APPROVED // The verification has been successfully completed and approved
  DECLINED // The verification has been rejected due to issues with submitted information
  KYC_EXPIRED // The previously verified KYC has expired and needs to be renewed
  IN_REVIEW // The verification requires manual review by the compliance team
  EXPIRED // The verification session has timed out before completion
  ABANDONED // The user started but did not complete the verification process
}

enum KYCProvider {
  DIDIT
  OTHER
}

model UserKYC {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Didit.me specific fields
  diditSessionId  String? @unique
  diditWorkflowId String?
  sessionUrl      String?
  callbackUrl     String?

  // Verification status and data
  status   KYCStatus   @default(NOT_STARTED)
  provider KYCProvider @default(DIDIT)

  // Verification results
  verificationData Json? // Store verification results from Didit
  rejectionReason  String? // Reason for rejection if applicable

  // Metadata
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  verifiedAt DateTime? // When verification was completed
  expiresAt  DateTime? // When the verification session expires

  @@unique([userId, provider]) // One active verification per provider per user
}

model Rating {
  id          String   @id @default(uuid())
  giver_id    String // User giving the rating
  receiver_id String // User receiving the rating
  trip_id     String // Trip being rated
  request_id  String? // Optional: specific request being rated
  rating      Int // Rating value (1-5)
  comment     String? // Optional comment
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  giver    User         @relation("RatingGiver", fields: [giver_id], references: [id], onDelete: Cascade)
  receiver User         @relation("RatingReceiver", fields: [receiver_id], references: [id], onDelete: Cascade)
  trip     Trip         @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  request  TripRequest? @relation(fields: [request_id], references: [id], onDelete: Cascade)

  @@unique([giver_id, receiver_id, trip_id]) // Prevent duplicate ratings for same trip
}

model Alert {
  id            String    @id @default(uuid())
  user_id       String
  depature      String
  destination   String
  form_date     DateTime?
  to_date       DateTime?
  notificaction Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Notification {
  id      String @id @default(uuid())
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id String

  title   String
  message String
  type    NotificationType // enum for categorizing
  data    Json? // extra metadata (e.g. { "postId": "123" })

  read      Boolean   @default(false) // track read/unread
  createdAt DateTime  @default(now())
  read_at   DateTime?
}

enum NotificationType {
  SYSTEM
  REQUEST
  ALERT
}

// Payment & Wallet Enums
enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  DISPUTED
}

enum TransactionType {
  CREDIT // Money added to wallet
  DEBIT // Money removed from wallet
}

enum TransactionSource {
  ORDER // From completed order
  WITHDRAW // Withdrawal request
  ADJUSTMENT // Manual adjustment by admin
  REFUND // Refund to sender
  COMMISSION // Platform commission deduction
  TRIP_EARNING // Trip earning
  FEE // Fee deduction
  CANCELLATION_COMPENSATION // Traveler compensation for cancellation
  VELRO_FEE // Velro platform fee
  PAYMENT_CANCELLATION // PaymentIntent cancellation (not captured)
  TRIP_PAYMENT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  ONHOLD
  COMPLETED
  FAILED
  PENDIND
  IN_PROGRES
  SEND
  FAIL
  RECEIVED
}

enum TransactionProvider {
  MTN
  ORANGE
  STRIPE
}

enum WalletState {
  ACTIVE
  BLOCKED
}

model Wallet {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  available_balance Decimal @default(0.00) @db.Decimal(10, 2) // to be removed
  hold_balance      Decimal @default(0.00) @db.Decimal(10, 2) // to be removed
  total_balance     Decimal @default(0.00) @db.Decimal(10, 2)

  available_balance_xaf Decimal @default(0) @db.Decimal(10, 2)
  hold_balance_xaf      Decimal @default(0) @db.Decimal(10, 2)

  available_balance_usd Decimal @default(0) @db.Decimal(10, 2)
  hold_balance_usd      Decimal @default(0) @db.Decimal(10, 2)

  available_balance_eur Decimal @default(0) @db.Decimal(10, 2)
  hold_balance_eur      Decimal @default(0) @db.Decimal(10, 2)

  available_balance_cad Decimal @default(0) @db.Decimal(10, 2)
  hold_balance_cad      Decimal @default(0) @db.Decimal(10, 2)

  state          WalletState @default(BLOCKED)
  currency       String      @default("XAF") // or USD, EUR, etc.
  status_message String?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  transactions Transaction[]

  // removed legacy stripe balance fields: available_balance_stripe, pending_balance_stripe, withdrawn_total_stripe

  @@index([userId])
}

model Transaction {
  id               String              @id @default(uuid())
  userId           String
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip_id          String?
  request_id       String?
  amount_requested Decimal             @db.Decimal(10, 2)
  fee_applied      Decimal             @db.Decimal(10, 2)
  amount_paid      Decimal             @db.Decimal(10, 2)
  wallet_id        String
  currency         String
  status_message   String?
  description      String? // Human-readable description
  metadata         Json? // Additional data
  reference        String?             @unique
  balance_after    Decimal?            @db.Decimal(10, 2)
  createdAt        DateTime            @default(now())
  processedAt      DateTime? // When transfer was completed
  updatedAt        DateTime            @updatedAt
  type             TransactionType
  source           TransactionSource
  status           TransactionStatus   @default(PENDING)
  provider         TransactionProvider
  provider_id      String?

  stripe_transfer_id String? @unique
  stripe_account_id  String?

  phone_number String?

  wallet  Wallet       @relation(fields: [wallet_id], references: [id])
  trip    Trip?        @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  request TripRequest? @relation(fields: [request_id], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([reference])
  @@index([stripe_transfer_id])
}

model Otp {
  id         String   @id @default(uuid())
  code       String
  email      String?
  phone      String?
  type       OtpType
  expiresAt  DateTime
  verified   Boolean  @default(false)
  access_key String?  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OtpType {
  LOGIN
  SIGNUP
  FORGOT_PASSWORD
  VERIFY_EMAIL
}

model AccountDeleteRequest {
  id        String              @id @default(uuid())
  email     String
  reason    String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  status    deleteRequestStatus @default(PENDING)

  // Relation
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id String

  @@index([user_id])
  @@index([email])
}

enum deleteRequestStatus {
  PENDING
  APPROVED
  REJECTED
}
