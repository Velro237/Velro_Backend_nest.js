generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Provider {
  GOOGLE
  APPLE
}

model User {
  id        String        @id @default(uuid())
  email     String        @unique
  password  String?
  name      String?
  picture   String?
  role      UserRole      @default(USER)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  trips     Trip[]
  requests  TripRequest[]
  messages  Message[]
  chats     ChatMember[]

  reportsSubmitted Report[] @relation("ReportReporter")
  reportsReceived  Report[] @relation("ReportReported")
  reportsReplied   Report[] @relation("ReportReplier")
  refreshTokens RefreshToken[]
  accounts      Account[]
}

model Account {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider          Provider
  providerAccountId String // "sub" (Google/Apple subject)
  accessToken       String?
  refreshToken      String?
  idToken           String?
  expiresAt         DateTime?

  @@unique([provider, providerAccountId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique // (en pratique: stocke un hash)
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Chat {
  id      String  @id @default(uuid())
  name    String?
  trip_id String? @unique // Optional: link to trip request (unique for one-to-one)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ChatMember[]
  messages Message[]
  trip     Trip?        @relation(fields: [trip_id], references: [id], onDelete: Cascade)
}

model ChatMember {
  id        String   @id @default(uuid())
  chat_id   String
  user_id   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  joinedAt DateTime @default(now())

  // Relations
  chat Chat @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, chat_id]) // Prevent duplicate memberships
}

model Message {
  id String @id @default(uuid())

  chat_id   String
  sender_id String
  chat      Chat   @relation(fields: [chat_id], references: [id], onDelete: Cascade)
  sender    User   @relation(fields: [sender_id], references: [id], onDelete: Cascade)

  content    String? // Text message
  image_url  String? // Optional for media messages
  request_id String? // Optional for request messages

  type MessageType @default(TEXT)

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // Optional: for threaded messages/replies
  reply_to_id String?
  reply_to    Message?  @relation("MessageReplies", fields: [reply_to_id], references: [id])
  replies     Message[] @relation("MessageReplies")

  // Relation to TripRequest (if the message references a trip request)
  request TripRequest? @relation(fields: [request_id], references: [id], onDelete: Cascade)
}

